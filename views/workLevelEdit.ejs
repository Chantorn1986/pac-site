<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Work Level</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <%- include('partials/nav'); %>
    <div class="ms-4 me-4">
        
        <div class="row mb-3">
            <div class="col-md-3">
            </div> 
            <div class="col-md-6">
                <h1>Edit Work Level</h1>
                <form action="/workLevel/Edit/<%= workLevel.id %>" method="POST">

                    <div class="row mb-3">            
                        <label for="workLevelNoE" class="form-label">NO.</label>
                        <input type="text" name="workLevelNoE" value="<%= workLevel.no %>" required class="form-control" required>
                    </div>
                    <div class="row mb-3">            
                        <label for="workLevelCodeE" class="form-label">Code</label>
                        <input type="text" name="workLevelCodeE" value="<%= workLevel.code %>" required class="form-control" required>
                    </div>
                    <div class="row mb-3">            
                        <label for="workLevelNameTHE" class="form-label">Work level name Thai</label>
                        <input type="text" name="workLevelNameTHE" value="<%= workLevel.nameTH %>" required class="form-control" required>
                    </div>
                    <div class="row mb-3">            
                        <label for="workLevelNameENE" class="form-label">Work level name English</label>
                        <input type="text" name="workLevelNameENE" value="<%= workLevel.nameEN %>" required class="form-control" required>
                    </div>

                    <button type="submit" class="btn btn-success">Update</button>
                </form>

                    <hr>
                    <a href="/workLevel" class="btn btn-warning">Go back</a>
            </div>
            <div class="col-md-3">

            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>