<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit product</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <%- include('partials/nav'); %>
    <div class="ms-4 me-4">
    <h1>Edit product</h1>
    <form action="/edit/<%= product.id %>" method="POST" enctype="multipart/form-data">
        <div>
            <label for="name">Name:</label>
            <input type="text" name="name" value="<%= product.name %>" required placeholder="enter product name">
        </div>

        <div>
            <label for="description">Description:</label>
            <textarea name="description" required placeholder="enter product description">
                <%= product.description %>
            </textarea>
        </div>

        <div>
            <label for="image">Image:</label>
            <% if (product.image) { %>
                <img src="/uploads/<%= product.image %>" width="100" />
                <input type="hidden" name="oldImage" value="<%= product.image %>">
            <% } %>
            <input type="file" name="image">
        </div>

        <button type="submit">Update</button>
    </form>

    <hr>
    <a href="/">Go back</a>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>