<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit department</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <%- include('partials/nav'); %>
    <div class="ms-4 me-4">
        <h1>Edit department</h1>
        <div class="row mb-3">
            <div class="col-md-6">
                <form action="/department/Edit/<%= department.id %>" method="POST">

                    <div class="row mb-3">            
                        <label for="departmentNoE" class="form-label">NO.</label>
                        <input type="text" name="departmentNoE" value="<%= department.no %>" required placeholder="enter no" class="form-control" required>
                    </div>
                    <div class="row mb-3">            
                        <label for="departmentCodeE" class="form-label">Code</label>
                        <input type="text" name="departmentCodeE" value="<%= department.code %>" required placeholder="enter department code" class="form-control" required>
                    </div>
                    <div class="row mb-3">            
                        <label for="departmentNameTHE" class="form-label">Department name Thai</label>
                        <input type="text" name="departmentNameTHE" value="<%= department.nameTH %>" required placeholder="enter department name Thai" class="form-control" required>
                    </div>
                    <div class="row mb-3">            
                        <label for="departmentNameENE" class="form-label">Department name English</label>
                        <input type="text" name="departmentNameENE" value="<%= department.nameEN %>" required placeholder="enter department name English" class="form-control" required>
                    </div>

                    <button type="submit" class="btn btn-success">Update</button>
                </form>

                    <hr>
                    <a href="/department" class="btn btn-warning">Go back</a>
            </div>
            <div class="col-md-6">

            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>