<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit user</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <%- include('partials/nav'); %>
    <div class="ms-4 me-4">
        <h1>Edit users</h1>
        <div class="row mb-3">
            <div class="col-md-6">
                <form action="/user/Edit/<%= users.id %>" method="POST" enctype="multipart/form-data">
                    <div class="row mb-3">
                        <label for="userNameE" class="form-label">Name</label>
                        <input type="text" name="userNameE" value="<%= users.name %>" required placeholder="enter product name" class="form-control">
                    </div>
                    <div class="row mb-3">            
                        <label for="userEmailE" class="form-label">Email</label>
                        <input type="email" name="userEmailE" value="<%= users.email %>" required placeholder="enter email" class="form-control" required>
                    </div>
                    <div class="row mb-3">            
                        <label for="userPasswordE" class="form-label">Password</label>
                        <input type="password" name="userPasswordE" required placeholder="enter password" class="form-control" required>
                    </div>
                    <div class="row mb-3">
                        <label for="userRoleE" class="form-label">Role</label>
                        <select name="userRoleE" class="form-select" value="<%= users.role %>" aria-label="Default select example">
                            <option value="USER">USER</option>
                            <option value="LEADER">LEADER</option>
                            <option value="HR">HR</option>
                            <option value="MANAGER">MANAGER</option>
                            <option value="ADMIN">ADMIN</option>
                          </select>
                    </div>

                    <button type="submit" class="btn btn-success">Update</button>
                </form>

                    <hr>
                    <a href="/user" class="btn btn-warning">Go back</a>
            </div>
            <div class="col-md-6">

            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>