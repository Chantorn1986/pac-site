<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Position</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <%- include('partials/nav'); %>
    <div class="ms-4 me-4">
    
        <div class="row mb-3">
            <div class="col-md-3">
            </div> 
            <div class="col-md-6">
                <h1>Create new Position</h1>
                <form action="/position/Add" method="POST">
                    <div class="row mb-3">            
                        <label for="positionNo" class="form-label">NO.</label>
                        <input type="text" name="positionNo" required placeholder="enter no" class="form-control" required>
                    </div>
                    <div class="row mb-3">            
                        <label for="positionNameTH" class="form-label">Position name Thai</label>
                        <input type="text" name="positionNameTH" required placeholder="enter Position name Thai" class="form-control" required>
                    </div>
                    <div class="row mb-3">            
                        <label for="positionNameEN" class="form-label">Position name English</label>
                        <input type="text" name="positionNameEN" required placeholder="enter Position name English" class="form-control" required>
                    </div>

                    <button type="submit" class="btn btn-success">Create</button>
                </form>
                <hr>
                    <a href="/position" class="btn btn-warning">Go back</a>
            </div> 
            <div class="col-md-3">

            </div>  
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>