<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Position</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <%- include('partials/nav'); %>
    <div class="ms-4 me-4">
        <div class="row mb-3">
            <div class="col-md-3">

            </div> 
            <div class="col-md-6">
                <h1>>Edit Position</h1>
                <form action="/position/Edit/<%= position.id %>" method="POST">

                    <div class="row mb-3">            
                        <label for="positionNoE" class="form-label">NO.</label>
                        <input type="text" name="positionNoE" value="<%= position.no %>" required class="form-control" required>
                    </div>
                    <div class="row mb-3">            
                        <label for="positionNameTHE" class="form-label">Position name Thai</label>
                        <input type="text" name="positionNameTHE" value="<%= position.nameTH %>" required class="form-control" required>
                    </div>
                    <div class="row mb-3">            
                        <label for="positionNameENE" class="form-label">Position name English</label>
                        <input type="text" name="positionNameENE" value="<%= position.nameEN %>" required class="form-control" required>
                    </div>

                    <button type="submit" class="btn btn-success">Update</button>
                </form>

                    <hr>
                    <a href="/position" class="btn btn-warning">Go back</a>
            </div>
            <div class="col-md-3">

            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>